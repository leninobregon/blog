# Activar RewriteEngine
RewriteEngine On

# Base path
RewriteBase /proyecto/blog_responsivo/

# Evitar listado de directorios (Muy importante para seguridad)
Options -Indexes

# Bloquear acceso directo a archivos de configuración
<FilesMatch "^(config\.php|config\.php|db/)">
    Require all denied
</FilesMatch>

# Bloquear acceso a la carpeta db desde fuera
RewriteRule ^db/ - [F,L]

# --- URLs LIMPIAS ---
# Permite entrar a /post en lugar de /post.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# --- MVC ROUTING ---
# Redirige todo a index.php para el MVC
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# Redirigir errores 404 al blog
ErrorDocument 404 /proyecto/blog_responsivo/
